DEBUG 2025-04-19 19:50:35,380 utils debug_sql (0.001) INSERT INTO `version_tracker_appversion` (`app_name`, `version_number`, `version_type`, `release_date`, `code_hash`, `changed_files`, `system_info`, `author_id`, `major`, `minor`, `patch`, `build`, `previous_version_id`, `is_final`, `is_active`) VALUES ('version_tracker', '1.0.0.1290', 'build', '2025-04-19 16:20:35.366157', 'e024d4963d10093c9fc57ce84d055ddc890f39480c69d84404ce5e10544d0de7', '[\"Modified: version.py\"]', '{\"os_name\": \"Windows\", \"os_version\": \"10.0.26100\", \"machine\": \"AMD64\", \"processor\": \"Intel64 Family 6 Model 186 Stepping 3, GenuineIntel\", \"username\": \"BlackMan\", \"hostname\": \"IT\"}', 1, 1, 0, 0, 1290, 3870, 0, 1); args=['version_tracker', '1.0.0.1290', 'build', '2025-04-19 16:20:35.366157', 'e024d4963d10093c9fc57ce84d055ddc890f39480c69d84404ce5e10544d0de7', '["Modified: version.py"]', '{"os_name": "Windows", "os_version": "10.0.26100", "machine": "AMD64", "processor": "Intel64 Family 6 Model 186 Stepping 3, GenuineIntel", "username": "BlackMan", "hostname": "IT"}', 1, 1, 0, 0, 1290, 3870, False, True]; alias=default
