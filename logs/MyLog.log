DEBUG 2025-04-29 15:39:17,979 utils debug_sql (0.001) INSERT INTO `version_tracker_appversion` (`app_name`, `version_number`, `version_type`, `release_date`, `code_hash`, `changed_files`, `system_info`, `author_id`, `major`, `minor`, `patch`, `build`, `previous_version_id`, `is_final`, `is_active`) VALUES ('version_tracker', '1.0.0.1473', 'build', '2025-04-29 12:09:17.965850', 'ec2c6b1a5e2b5dd9a305482c629eab9dc2d296ffe101cebec3d1c953962b39ab', '[\"Modified: version.py\"]', '{\"os_name\": \"Windows\", \"os_version\": \"10.0.26100\", \"machine\": \"AMD64\", \"processor\": \"Intel64 Family 6 Model 186 Stepping 3, GenuineIntel\", \"username\": \"BlackMan\", \"hostname\": \"IT\"}', 1, 1, 0, 0, 1473, 4419, 0, 1); args=['version_tracker', '1.0.0.1473', 'build', '2025-04-29 12:09:17.965850', 'ec2c6b1a5e2b5dd9a305482c629eab9dc2d296ffe101cebec3d1c953962b39ab', '["Modified: version.py"]', '{"os_name": "Windows", "os_version": "10.0.26100", "machine": "AMD64", "processor": "Intel64 Family 6 Model 186 Stepping 3, GenuineIntel", "username": "BlackMan", "hostname": "IT"}', 1, 1, 0, 0, 1473, 4419, False, True]; alias=default
